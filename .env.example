# Copy this file to `.env` and fill in the keys you have.
# Vite only exposes variables prefixed with VITE_ to the browser.
# Restart `npm run dev` after editing.

# --- AI ---
# Google AI Studio: https://aistudio.google.com/app/apikey
VITE_GEMINI_API_KEY=
# Optional: override the model (default: gemini-2.5-flash)
VITE_GEMINI_MODEL=gemini-2.5-flash

# Exa (maritime law research agent): https://dashboard.exa.ai/api-keys
VITE_EXA_API_KEY=

# --- Data sources (optional, backend integrations) ---
# Global Fishing Watch: https://globalfishingwatch.org/our-apis/tokens
VITE_GFW_API_TOKEN=
# Copernicus / Sentinel-1 SAR: https://dataspace.copernicus.eu/
VITE_COPERNICUS_CLIENT_ID=
VITE_COPERNICUS_CLIENT_SECRET=

# --- Auth0 (clearance-based access) ---
# https://manage.auth0.com/
VITE_AUTH0_DOMAIN=
VITE_AUTH0_CLIENT_ID=
VITE_AUTH0_AUDIENCE=

# --- Storage (server-side only; do NOT expose via VITE_*) ---
MONGODB_URI=
